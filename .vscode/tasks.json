{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-NoProfile",
                "-File", "${workspaceFolder}/build.ps1",
                "-Task", "Build"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-NoProfile",
                "-File", "${workspaceFolder}/build.ps1",
                "-Task", "Clean"
            ],
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Rebuild",
            "dependsOn": ["Clean", "Build"],
            "dependsOrder": "sequence",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Test",
            "type": "shell",
            "command": "pwsh",
            "args": [
                "-ExecutionPolicy", "Bypass",
                "-NoProfile",
                "-File", "${workspaceFolder}/build.ps1",
                "-Task", "Test"
            ],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        }
    ]
}
